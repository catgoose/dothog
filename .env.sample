# Copy to .env or .env.dev and set values as needed.

# Server
# Port the server will listen on (required)
SERVER_LISTEN_PORT=

# Logging
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=

# Azure AD / Microsoft Graph
# Used for Crooner (user sign-in) and/or Graph API (app-only client credentials).
# Tenant ID, client ID, and client secret from your Azure app registration.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Azure user cache: hour of day to refresh (0-23). Default: 5 (5 AM) in production.
AZURE_USER_REFRESH_HOUR=

# Database (optional; used if you add DB-backed features)
DB_HOST=
DB_DATABASE=
DB_USER=
DB_PASSWORD=
